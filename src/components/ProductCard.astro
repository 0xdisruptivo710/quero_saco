---
import { Icon } from 'astro-icon/components';
interface Props { href: string; nome: string; resumo: string; categoria: string; categoriaId: string; icone: string; }
const { href, nome, resumo, categoria, categoriaId, icone } = Astro.props;
---
<a href={href} data-categoria={categoriaId} data-nome={nome.toLowerCase()}
   class="product-card group block bg-white border-2 border-ink overflow-hidden hover:-translate-y-1 transition-transform">
  <div class="aspect-[4/3] overflow-hidden bg-surface relative flex items-center justify-center border-b-2 border-ink">
    <Icon name={icone} class="absolute -right-8 -bottom-8 text-[10rem] text-ink/[0.04] pointer-events-none group-hover:text-brand/10 transition-colors duration-500" />
    <Icon name={icone} class="relative text-brand text-7xl group-hover:scale-110 transition-transform duration-500" />
  </div>
  <div class="p-6">
    <span class="text-brand font-bold text-xs uppercase tracking-widest">{categoria}</span>
    <h3 class="heading-font text-xl mt-2 mb-1 text-ink">{nome}</h3>
    <p class="text-steel text-sm">{resumo}</p>
  </div>
</a>
