---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';
const mapsSrc = `https://www.google.com/maps?q=${encodeURIComponent(site.address.mapsQuery)}&output=embed`;
---
<BaseLayout title="Contato" description="Fale com a QS Plastic & Paper: telefones, e-mail, horários e localização em Duque de Caxias - RJ.">
  <section class="max-w-site mx-auto px-4 md:px-8 py-16 grid lg:grid-cols-2 gap-12">
    <div>
      <h1 class="heading-font text-fluid-h2 text-ink mb-8">Contato</h1>
      <ul class="space-y-4 text-lg text-ink">
        <li class="flex items-center gap-3"><Icon name="ph:phone" class="text-brand text-2xl shrink-0" /><span><span class="font-bold">Atacadista:</span> {site.phones.atacadista}</span></li>
        <li class="flex items-center gap-3"><Icon name="ph:whatsapp-logo" class="text-brand text-2xl shrink-0" /><span><span class="font-bold">Comercial:</span> {site.phones.comercial}</span></li>
        <li class="flex items-center gap-3"><Icon name="ph:envelope-simple" class="text-brand text-2xl shrink-0" /><span>{site.email}</span></li>
        <li class="flex items-start gap-3"><Icon name="ph:clock" class="text-brand text-2xl shrink-0 mt-1" /><span>{site.hours.join(' · ')}</span></li>
        <li class="flex items-start gap-3"><Icon name="ph:map-pin" class="text-brand text-2xl shrink-0 mt-1" /><span>{site.address.street}, {site.address.district}, {site.address.city} — {site.address.cep}</span></li>
      </ul>
      <div class="mt-10">
        <h2 class="heading-font text-2xl text-ink mb-4">Envie uma mensagem</h2>
        <QuoteForm compact />
      </div>
    </div>
    <div id="localizacao" class="min-h-[400px] lg:min-h-full">
      <iframe
        title="Localização QS Plastic & Paper"
        src={mapsSrc}
        loading="lazy"
        class="w-full h-full min-h-[400px] border-2 border-ink"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </section>
</BaseLayout>
